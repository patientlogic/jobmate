# Note: Copy these variables in your .env file

# MySQL — set host, port, user, password, and database name (no DATABASE_URL required).

DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=
DATABASE_NAME=jobmate

# Optional: full URL overrides the fields above if set.
# DATABASE_URL=mysql://USER:PASSWORD@localhost:3306/jobmate

# Special characters in USER or PASSWORD are URL-encoded automatically. Leave DATABASE_PASSWORD blank if none.

# If you are running it on a remote server/homelab, you must update timezone otherwise activities times may shift
TZ=America/Edmonton

# App URL (Playwright, Vitest, NextAuth). Use the same host/port as `npm run dev` (default 3737).
APP_URL=http://localhost:3737

# For homelab server, change the following to your server ip ex: http://192.168.x.x:3737
NEXTAUTH_URL=http://localhost:3737

# AUTH_SECRET — set in production; generate e.g. openssl rand -base64 32
# To set manually, uncomment and provide your own value:
# AUTH_SECRET=

# ENCRYPTION_KEY is used to encrypt stored API keys (OpenAI, DeepSeek, RapidAPI)
# Must be stable across restarts — changing it will make all stored API keys unrecoverable
# Generate with: openssl rand -base64 32
# ENCRYPTION_KEY=

OPENAI_API_KEY=your-openai-api-key-here

# DeepSeek API Key - get from https://platform.deepseek.com
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# Google Gemini API Key - get from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# For homelab server, if you ollama is running on server, change the following to your ollamma ip ex: http://192.168.x.x:12345
OLLAMA_BASE_URL=http://127.0.0.1:11434

# AI Configuration
# The system uses LLM-based semantic extraction for intelligent, context-aware skill matching
# No configuration needed - semantic extraction is the default

RAPIDAPI_KEY=your-rapidapi-key-here
